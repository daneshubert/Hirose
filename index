<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HIROSE AMERICAS DASHBOARD</title>
    <style>
        body {
            margin: 0; padding: 0;
            background-color: #050a14;
            color: #ffffff;
            font-family: 'Helvetica Neue', Arial, sans-serif;
            overflow: hidden;
            height: 100vh;
            display: flex; flex-direction: column;
        }
        /* Header using Hirose Blue #5B95F1 */
        .header {
            background-color: #000000;
            padding: 20px 40px;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 4px solid #5B95F1; 
        }
        .header img { height: 60px; }
        /* Status using Hirose Green #80B341 */
        .status { color: #80B341; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; }
        
        .main { flex-grow: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: #1a1a1a; }
        .panel { background: #050a14; padding: 25px; display: flex; flex-direction: column; }
        .panel-title { color: #5B95F1; font-size: 12px; font-weight: 800; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 2px; }
        iframe { border: none; flex-grow: 1; width: 100%; border-radius: 4px; }
    </style>
</head>
<body>

    <div class="header">
        <!-- Ensures your uploaded logo file name matches exactly -->
        <img src="Hirose Logo Stacked.png" alt="Hirose Electric Americas">
        <div class="status">● GLOBAL CONNECTIVITY STATUS: ACTIVE</div>
    </div>

    <div class="main">
        <!-- Market & Industry Trends -->
        <div class="panel">
            <div class="panel-title">Market & Material Tracking</div>
            <div class="tradingview-widget-container" style="height:100%;width:100%">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-market-overview.js" async>
                {
                "colorTheme": "dark",
                "showChart": true,
                "locale": "en",
                "width": "100%", "height": "100%",
                "transparent": true,
                "symbolsGroups": [
                    {
                    "name": "Hirose Ecosystem",
                    "symbols": [
                        { "name": "TSE:6806", "displayName": "Hirose (TSE)" },
                        { "name": "COMEX:HG1!", "displayName": "Copper Future" },
                        { "name": "NASDAQ:NVDA", "displayName": "NVIDIA" },
                        { "name": "NASDAQ:AAPL", "displayName": "Apple" },
                        { "name": "NASDAQ:TSLA", "displayName": "Tesla" }
                    ]
                    }
                ]
                }
                </script>
            </div>
        </div>

        <!-- Global Visualizer (High-Tech Eye Candy) -->
        <div class="panel">
            <div class="panel-title">Global Network Visualization</div>
            <iframe src="https://embed.windy.com/embed2.html?lat=41.878&lon=-87.629&zoom=3&level=surface&overlay=wind&product=ecmwf&message=true&marker=true&calendar=now&pressure=true&type=map&location=coordinates&detail=true&metricWind=mph&metricTemp=%C2%B0F" frameborder="0"></iframe>
        </div>
    </div>

    <!-- Scrolling Ticker -->
    <div style="background: #000; padding: 10px 0;">
        <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async>
            {
            "symbols": [
                { "proName": "TSE:6806", "title": "HIROSE ELECTRIC" },
                { "proName": "NASDAQ:NVDA", "title": "NVIDIA" },
                { "proName": "NASDAQ:TSLA", "title": "TESLA" },
                { "proName": "NYSE:TM", "title": "TOYOTA" },
                { "proName": "COMEX:HG1!", "title": "COPPER" }
            ],
            "showSymbolLogo": true,
            "colorTheme": "dark",
            "isTransparent": true,
            "displayMode": "adaptive",
            "locale": "en"
            }
            </script>
        </div>
    </div>

</body>
</html>
