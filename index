<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HIROSE AMERICAS // COMMAND CENTER</title>
    <style>
        body {
            margin: 0; padding: 0;
            background-color: #050a14;
            color: #ffffff;
            font-family: 'Helvetica Neue', Arial, sans-serif;
            overflow: hidden;
            height: 100vh;
            display: grid;
            grid-template-rows: 80px 1fr 60px; /* Header, Main Content, Footer */
        }

        /* --- HIROSE BRANDED HEADER --- */
        .header {
            background-color: #000;
            padding: 0 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 4px solid #5B95F1; /* Hirose Blue */
        }
        .header img { height: 50px; }
        .status-tag {
            color: #80B341; /* Hirose Green */
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 14px;
        }

        /* --- MAIN DASHBOARD GRID --- */
        .dashboard {
            display: grid;
            grid-template-columns: 1.5fr 1fr; /* Left: Big Map, Right: Data Columns */
            gap: 15px;
            padding: 15px;
            background: #111;
        }

        .panel {
            background: #050a14;
            border: 1px solid rgba(91, 149, 241, 0.2);
            border-radius: 4px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .panel-header {
            padding: 10px 15px;
            font-size: 11px;
            font-weight: bold;
            color: #5B95F1;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            background: rgba(0,0,0,0.4);
            border-bottom: 1px solid rgba(91, 149, 241, 0.2);
        }

        iframe { border: none; width: 100%; height: 100%; flex-grow: 1; }

        /* --- FOOTER TICKER --- */
        .footer { background: #000; display: flex; align-items: center; }
    </style>
</head>
<body>

    <div class="header">
        <img src="Hirose Logo Stacked.png" alt="Hirose Electric Americas">
        <div class="status-tag">● GLOBAL CONNECTIVITY: OPTIMAL</div>
    </div>

    <div class="dashboard">
        <div class="panel">
            <div class="panel-header">Real-Time Global Infrastructure Health</div>
            <iframe src="https://cybermap.kaspersky.com/en/widget/"></iframe>
        </div>

        <div class="panel">
            <div class="panel-header">Raw Materials & Core Tech Partners</div>
            <div class="tradingview-widget-container" style="height:100%;width:100%">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-market-overview.js" async>
                {
                    "colorTheme": "dark", "showChart": true, "locale": "en", "width": "100%", "height": "100%", "transparent": true,
                    "symbolsGroups": [
                        { "name": "Hirose Supply Chain", "symbols": [
                            { "name": "TSE:6806", "displayName": "Hirose (Japan)" },
                            { "name": "COMEX:HG1!", "displayName": "Copper (Core Material)" },
                            { "name": "NASDAQ:NVDA", "displayName": "NVIDIA (Datacom)" },
                            { "name": "NASDAQ:AAPL", "displayName": "Apple (Consumer)" },
                            { "name": "NASDAQ:TSLA", "displayName": "Tesla (Auto)" }
                        ]}
                    ]
                }
                </script>
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="tradingview-widget-container" style="width: 100%;">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async>
            {
                "symbols": [
                    { "proName": "TSE:6806", "title": "HIROSE ELECTRIC" },
                    { "proName": "NASDAQ:MSFT", "title": "MICROSOFT" },
                    { "proName": "NASDAQ:AMZN", "title": "AMAZON" },
                    { "proName": "NYSE:TM", "title": "TOYOTA" },
                    { "proName": "NYSE:TEL", "title": "TE CONNECTIVITY" }
                ],
                "showSymbolLogo": true, "colorTheme": "dark", "isTransparent": true, "displayMode": "adaptive", "locale": "en"
            }
            </script>
        </div>
    </div>

</body>
</html>
