<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HIROSE // DISCOVERY</title>
    <style>
        body { margin: 0; padding: 0; background-color: #000; color: #ffffff; font-family: 'Helvetica Neue', Arial, sans-serif; overflow: hidden; height: 100vh; display: grid; grid-template-rows: 80px 1fr 60px; }
        .header { background-color: #000; padding: 0 40px; display: flex; justify-content: space-between; align-items: center; border-bottom: 4px solid #80B341; }
        .header img { height: 50px; }
        .status-tag { color: #80B341; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; font-size: 14px; }
        .main-content { position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #050a14; }
        #nasa-image { width: 100%; height: 100%; object-fit: cover; opacity: 0.6; }
        .overlay-text { position: absolute; left: 40px; bottom: 40px; max-width: 40%; background: rgba(0,0,0,0.7); padding: 20px; border-left: 4px solid #80B341; }
        .overlay-text h1 { margin: 0; font-size: 24px; color: #80B341; text-transform: uppercase; }
        .overlay-text p { margin: 10px 0 0; font-size: 14px; line-height: 1.4; color: #ccc; }
    </style>
</head>
<body>
    <div class="header">
        <img src="Hirose Logo Stacked.png" alt="Hirose">
        <div class="status-tag">● DISCOVERY MODE: NASA LIVE FEED</div>
    </div>
    <div class="main-content">
        <img id="nasa-image" src="" alt="NASA APOD">
        <div class="overlay-text">
            <h1 id="nasa-title">Loading Discovery Data...</h1>
            <p id="nasa-desc">Connecting to NASA deep space network for daily imagery updates.</p>
        </div>
    </div>
    <div style="background:#000; height:60px; display:flex; align-items:center;">
        <div class="tradingview-widget-container" style="width:100%;">
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async>
            {
                "symbols": [
                    { "proName": "OTC:HROEY", "title": "HIROSE AMERICAS" },
                    { "proName": "NASDAQ:AMZN", "title": "AMAZON BLUE ORIGIN" },
                    { "proName": "NASDAQ:TSLA", "title": "TESLA SPACEX" }
                ],
                "colorTheme": "dark", "isTransparent": true, "displayMode": "adaptive", "locale": "en"
            }
            </script>
        </div>
    </div>
    <script>
        async function fetchNASA() {
            try {
                const response = await fetch('https://api.nasa.gov/planetary/apod?api_key=DEMO_KEY');
                const data = await response.json();
                document.getElementById('nasa-image').src = data.url;
                document.getElementById('nasa-title').innerText = data.title;
                document.getElementById('nasa-desc').innerText = data.explanation.substring(0, 200) + '...';
            } catch (error) {
                console.log('NASA feed error');
            }
        }
        fetchNASA();
    </script>
</body>
</html>
